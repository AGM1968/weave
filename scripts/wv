#!/bin/bash
# wv — Weave CLI: In-memory graph for AI coding agents
# Fast, ephemeral task/context tracking via SQLite in tmpfs
# See: docs/WEAVE.md
#
# Modular architecture (v1.2):
#   lib/wv-config.sh   — configuration, hot zone, colors
#   lib/wv-db.sh       — database init, migrations, queries
#   lib/wv-validate.sh — ID generation, validation, edge types
#   lib/wv-cache.sh    — context cache management
#   cmd/wv-cmd-core.sh — init, add, done, ready, list, show, status, update, quick, ship
#   cmd/wv-cmd-graph.sh— block, link, resolve, related, edges, path, context
#   cmd/wv-cmd-data.sh — batch, plan, enrich-topology, sync, load, compact, prune, unarchive, clean-ghosts, learnings, refs, import, search, reindex, trails (alias: breadcrumbs)
#   cmd/wv-cmd-ops.sh  — doctor, recover, selftest, mcp-status, health, cache, preflight, digest, overview, session-summary, audit-pitfalls, pattern-audit, edge-types, guide, init-repo, help
#   cmd/wv-cmd-quality.sh — quality
#   cmd/wv-cmd-findings.sh — findings

set -euo pipefail

# ═══════════════════════════════════════════════════════════════════════════
# XDG-Compliant Module Resolution (v1.3)
# ═══════════════════════════════════════════════════════════════════════════
# Resolution order:
#   1. $SCRIPT_DIR/lib/ (dev mode — running from git checkout)
#   2. ~/.local/lib/weave/ (installed mode — XDG standard)
#
# This allows seamless switching between development and production.

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
export WV_CLI="${WV_CLI:-$SCRIPT_DIR/wv}"
WV_LIB_DIR="${WV_LIB_DIR:-}"

_wv_append_user_tool_path() {
    local dir="$1"
    [ -d "$dir" ] || return 0
    case ":${PATH:-}:" in
        *":$dir:"*) return 0 ;;
    esac
    PATH="${PATH:+$PATH:}$dir"
}

if [ "${WV_DISABLE_USER_TOOL_PATHS:-0}" != "1" ]; then
    _wv_append_user_tool_path "$HOME/.local/bin"
    _wv_append_user_tool_path "$HOME/.cargo/bin"
    export PATH
fi

# Resolve library directory: dev (relative) or installed (XDG)
if [ -z "$WV_LIB_DIR" ]; then
    if [ -f "$SCRIPT_DIR/lib/wv-config.sh" ]; then
        # Dev mode: running from source checkout
        WV_LIB_DIR="$SCRIPT_DIR"
    elif [ -f "${HOME}/.local/lib/weave/lib/wv-config.sh" ]; then
        # Installed mode: XDG standard location
        WV_LIB_DIR="${HOME}/.local/lib/weave"
    else
        echo "wv: cannot find library modules" >&2
        echo "  Checked: $SCRIPT_DIR/lib/wv-config.sh" >&2
        echo "  Checked: ${HOME}/.local/lib/weave/lib/wv-config.sh" >&2
        exit 1
    fi
fi

# Source library modules (order matters: config first, then db needs config vars)
source "$WV_LIB_DIR/lib/wv-config.sh"
source "$WV_LIB_DIR/lib/wv-db.sh"
source "$WV_LIB_DIR/lib/wv-validate.sh"
source "$WV_LIB_DIR/lib/wv-cache.sh"
source "$WV_LIB_DIR/lib/wv-journal.sh"
source "$WV_LIB_DIR/lib/wv-gh.sh"
source "$WV_LIB_DIR/lib/wv-delta.sh"

# Source command modules
source "$WV_LIB_DIR/cmd/wv-cmd-core.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-graph.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-data.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-ops.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-quality.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-findings.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-analyze.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-indexer.sh"
source "$WV_LIB_DIR/cmd/wv-cmd-query.sh"

# ═══════════════════════════════════════════════════════════════════════════
# Main Dispatcher
# ═══════════════════════════════════════════════════════════════════════════

_resolve_first_id() {
    # Usage: _resolve_first_id <cmd_func> [args...]
    # Resolves the first non-flag argument from alias to wv-xxxx ID,
    # then calls cmd_func with the resolved args.
    local cmd_func="$1"
    shift

    local new_args=()
    local resolved_one=false
    for arg in "$@"; do
        if [ "$resolved_one" = true ] || [[ "$arg" == -* ]]; then
            new_args+=("$arg")
        elif [[ "$arg" =~ ^wv-[a-f0-9]{4,6}$ ]]; then
            new_args+=("$arg")
            resolved_one=true
        else
            local rid
            rid=$(resolve_id "$arg" 2>/dev/null)
            if [ -n "$rid" ]; then
                new_args+=("$rid")
                resolved_one=true
            else
                new_args+=("$arg")
                resolved_one=true
            fi
        fi
    done
    "$cmd_func" "${new_args[@]}"
}

_route_command_help_if_requested() {
    local cmd="$1"
    shift || true

    if [ $# -eq 0 ]; then
        return 1
    fi

    case "$1" in
        --help|-h)
            cmd_help "$cmd" "${@:2}"
            return 0
            ;;
    esac

    return 1
}

_wv_dispatch() {
    local cmd="${1:-help}"
    shift || true

    if [ "$cmd" != "help" ] && [ "$cmd" != "--help" ] && [ "$cmd" != "-h" ]; then
        if _route_command_help_if_requested "$cmd" "$@"; then
            return 0
        fi
    fi

    case "$cmd" in
        # Core commands
        init)   cmd_init "$@" ;;
        add)    cmd_add "$@" ;;
        done)       _resolve_first_id cmd_done "$@" ;;
        batch-done) cmd_batch_done "$@" ;;
        bulk-update) cmd_bulk_update "$@" ;;
        delete)     _resolve_first_id cmd_delete "$@" ;;
        work)   _resolve_first_id cmd_work "$@" ;;
        ready)  cmd_ready "$@" ;;
        list)   cmd_list "$@" ;;
        show)   _resolve_first_id cmd_show "$@" ;;
        status) cmd_status "$@" ;;
        pending-close) cmd_pending_close "$@" ;;
        update) _resolve_first_id cmd_update "$@" ;;
        touch)         _resolve_first_id cmd_touch "$@" ;;
        allowed-tools) _resolve_first_id cmd_allowed_tools "$@" ;;
        quick)  cmd_quick "$@" ;;
        ship)   _resolve_first_id cmd_ship "$@" ;;
        ship-agent) _resolve_first_id cmd_ship_agent "$@" ;;

        # Graph commands
        block)   _resolve_first_id cmd_block "$@" ;;
        link)    cmd_link "$@" ;;    # link takes two IDs; resolve inside
        unlink)  cmd_unlink "$@" ;; # unlink takes two IDs; resolve inside
        resolve) _resolve_first_id cmd_resolve "$@" ;;
        related) _resolve_first_id cmd_related "$@" ;;
        edges)   _resolve_first_id cmd_edges "$@" ;;
        path)    _resolve_first_id cmd_path "$@" ;;
        tree)    cmd_tree "$@" ;;
        context) _resolve_first_id cmd_context "$@" ;;
        impact)  cmd_impact "$@" ;;

        # Data commands
        batch)       cmd_batch "$@" ;;
        plan)        cmd_plan "$@" ;;
        enrich-topology) cmd_enrich_topology "$@" ;;
        sync)        cmd_sync "$@" ;;
        load)        cmd_load "$@" ;;
        compact)     cmd_compact "$@" ;;
        prune)       cmd_prune "$@" ;;
        unarchive)   cmd_unarchive "$@" ;;
        clean-ghosts) cmd_clean_ghosts "$@" ;;
        learnings)   cmd_learnings "$@" ;;
        refs)        cmd_refs "$@" ;;
        import)      cmd_import "$@" ;;
        search)      cmd_search "$@" ;;
        reindex)     cmd_reindex "$@" ;;
        trails)      cmd_trails "$@" ;;
        breadcrumbs) cmd_trails "$@" ;;  # back-compat alias (one release) for `trails`
        
        # Ops commands
        bootstrap)       cmd_bootstrap "$@" ;;
        bootstrap-agent) cmd_bootstrap_agent "$@" ;;
        doctor)          cmd_doctor "$@" ;;
        hotzone)         cmd_hotzone "$@" ;;
        test-record)     cmd_test_record "$@" ;;
        self-update)     cmd_self_update "$@" ;;
        uninstall)       cmd_uninstall "$@" ;;
        recover)         cmd_recover "$@" ;;
        selftest)        cmd_selftest "$@" ;;
        mcp-status)      cmd_mcp_status "$@" ;;
        health)          cmd_health "$@" ;;
        cache)           cmd_cache "$@" ;;
        preflight)       _resolve_first_id cmd_preflight "$@" ;;
        digest)          cmd_digest "$@" ;;
        overview)        cmd_overview "$@" ;;
        session-summary) cmd_session_summary "$@" ;;
        audit-pitfalls)  cmd_audit_pitfalls "$@" ;;
        pattern-audit)   cmd_pattern_audit "$@" ;;
        edge-types)      cmd_edge_types "$@" ;;
        guide)           cmd_guide "$@" ;;
        init-repo)       cmd_init_repo "$@" ;;
        config)          cmd_config "$@" ;;

        # Quality / analysis / query commands
        quality)            cmd_quality "$@" ;;
        findings)           cmd_findings "$@" ;;
        validate-finding)   _resolve_first_id cmd_validate_finding "$@" ;;
        analyze)            cmd_analyze "$@" ;;
        index)           cmd_index "$@" ;;
        query)           cmd_query "$@" ;;
        help|--help|-h)  cmd_help "$@" ;;
        version|--version|-v) echo "wv $WV_VERSION" ;;
        
        *)
            echo -e "${RED}Unknown command: $cmd${NC}" >&2
            cmd_help
            return 1
            ;;
    esac
}

main() {
    local cmd="${1:-help}"

    # Run cache: serve cached stdout for pure-read commands (status, ready, list)
    # Disable with WV_RUN_CACHE=0
    if [ "${WV_RUN_CACHE:-1}" = "1" ] && _wv_run_cache_is_read_cmd "$cmd"; then
        wv_run_cache_wrap _wv_dispatch "$@"
        return $?
    fi

    local rc=0
    _wv_dispatch "$@" || rc=$?

    # Invalidate run cache after successful writes
    if [ "$rc" -eq 0 ] && _wv_run_cache_is_write_cmd "$cmd"; then
        wv_run_cache_invalidate
    fi

    return "$rc"
}

# ═══════════════════════════════════════════════════════════════════════════
# Call Instrumentation (opt-in via WV_CALL_LOG)
# ═══════════════════════════════════════════════════════════════════════════
# When WV_CALL_LOG is set, each invocation appends one JSONL line:
#   {"ts":<epoch>,"cmd":"wv <subcmd>","stdout_bytes":<n>,"stderr_bytes":<n>,"elapsed_ms":<n>,"source":<src>}
#
# source values: "shell" (interactive terminal), "hook" (Claude Code hook),
#                "sync" (wv sync --gh / weave_gh), "agent" (Claude Code tool call,
#                via settings.json env), "test" (suite runs via run-all.sh or the
#                pre-commit suite gate)
# Callers set WV_CALL_SOURCE before invoking wv to tag their traffic.
#
# Enable:  wv config enable session-analysis
# Analyse: wv analyze sessions --call-stats [--source=agent|shell|hook|sync|test]
# Zero overhead when unset.

if [[ -n "${WV_CALL_LOG:-}" ]]; then
    _wv_ts_start=$(date +%s%3N)
    _wv_ts_epoch=$(date +%s.%6N)
    _wv_out=$(mktemp -t wv-calllog-XXXXXX)
    _wv_err=$(mktemp -t wv-calllog-err-XXXXXX)
    _wv_exit=0
    set +e
    main "$@" > >( tee "$_wv_out" ) 2> >( tee "$_wv_err" >&2 )
    _wv_exit=$?
    set -e
    _wv_ts_end=$(date +%s%3N)
    _wv_elapsed=$((_wv_ts_end - _wv_ts_start))
    _wv_stdout_bytes=$(wc -c < "$_wv_out")
    _wv_stderr_bytes=$(wc -c < "$_wv_err")
    rm -f "$_wv_out" "$_wv_err"
    _wv_source="${WV_CALL_SOURCE:-shell}"
    printf '{"ts":%s,"cmd":"wv %s","stdout_bytes":%d,"stderr_bytes":%d,"elapsed_ms":%d,"source":"%s"}\n' \
        "$_wv_ts_epoch" "${1:-help}" "$_wv_stdout_bytes" "$_wv_stderr_bytes" "$_wv_elapsed" "$_wv_source" \
        >> "$WV_CALL_LOG" 2>/dev/null || true
    exit "$_wv_exit"
else
    main "$@"
fi

{
  "servers": {
    "weave": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp/dist/index.js"],
      "env": {
        "WV_PATH": "${workspaceFolder}/scripts/wv"
      }
    },
    "weave-inspect": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp/dist/index.js", "--scope=inspect"],
      "env": {
        "WV_PATH": "${workspaceFolder}/scripts/wv"
      }
    }
  }
}

{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://weave.dev/contracts/durability-v1.schema.json","$defs":{"durability_status":{"type":"object","additionalProperties":false,"required":["graph_revision","graph_representation","worktree","local_commit","upstream"],"properties":{"graph_revision":{"type":"integer","minimum":0},"graph_representation":{"enum":["live_only","serialized"]},"worktree":{"enum":["clean","graph_dirty","dirty_unrelated","dirty_mixed","unknown"]},"local_commit":{"enum":["absent","stale","contains_revision","unknown"]},"upstream":{"enum":["unconfirmed","confirms_revision","unavailable","unknown"]}},"allOf":[{"if":{"properties":{"upstream":{"const":"confirms_revision"}}},"then":{"properties":{"local_commit":{"const":"contains_revision"},"graph_representation":{"const":"serialized"}}}},{"if":{"properties":{"local_commit":{"const":"contains_revision"}}},"then":{"properties":{"graph_representation":{"const":"serialized"}}}}]}}}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/contracts/policy-v1.schema.json",
  "$defs": {
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "event_id", "graph_revision", "policy_revision", "evidence_ids", "reason_codes", "affected_nodes", "affected_files", "remediation"],
      "properties": {
        "decision": {"enum": ["allow", "allow_with_advisories", "deny"]},
        "event_id": {"type": "string", "minLength": 1},
        "graph_revision": {"type": "integer", "minimum": 0},
        "policy_revision": {"type": "string", "minLength": 1},
        "evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "reason_codes": {"type": "array", "items": {"$ref":"#/$defs/reason_code"}, "uniqueItems": true},
        "affected_nodes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "affected_files": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "remediation": {"type": "array", "items": {"type": "object"}},
        "host_mapping": {"type": ["object", "null"]}
      },
      "allOf": [
        {"if":{"properties":{"decision":{"const":"allow"}}},"then":{"properties":{"reason_codes":{"type":"array","maxItems":0},"remediation":{"type":"array","maxItems":0}}}},
        {"if":{"properties":{"decision":{"const":"deny"}}},"then":{"properties":{"reason_codes":{"type":"array","minItems":1},"remediation":{"type":"array","minItems":1}}}},
        {"if":{"properties":{"decision":{"const":"allow_with_advisories"}}},"then":{"properties":{"reason_codes":{"type":"array","minItems":1}}}}
      ]
    },
    "reason_code": {"enum":["evidence_missing","evidence_stale","graph_integrity_failed","policy_preflight_failed","repository_state_unknown"]}
  }
}

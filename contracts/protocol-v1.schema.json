{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/contracts/protocol-v1.schema.json",
  "title": "Weave IPC v1 protocol envelope",
  "type": "object",
  "$defs": {
    "repository_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_root", "repository_id", "worktree_id"],
      "properties": {
        "canonical_root": {"type": "string", "minLength": 1},
        "repository_id": {"type": "string", "pattern": "^git:[0-9a-f]{40}$"},
        "worktree_id": {"type": "string", "pattern": "^git-worktree:[0-9a-f]{40}$"}
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit", "returned", "truncated"],
      "properties": {
        "limit": {"type": "integer", "minimum": 1, "maximum": 200},
        "returned": {"type": "integer", "minimum": 0},
        "total_known": {"type": "integer", "minimum": 0},
        "truncated": {"type": "boolean"},
        "continuation": {"type": ["string", "null"]}
      },
      "allOf": [
        {"if":{"properties":{"truncated":{"const":true}}},"then":{"properties":{"continuation":{"type":"string","minLength":1}},"required":["continuation"]}},
        {"if":{"properties":{"truncated":{"const":false}}},"then":{"properties":{"continuation":{"const":null}},"required":["continuation"]}}
      ]
    },
    "durability": {"$ref": "durability-v1.schema.json#/$defs/durability_status"},
    "error": {"$ref": "errors-v1.schema.json#/$defs/wire_error"},
    "actor": {"type":"object","additionalProperties":false,"required":["id","kind","harness","instance_id","attestation"],"properties":{"id":{"type":"string","minLength":1},"kind":{"enum":["codex","claude","copilot","ci","runtime","custom"]},"harness":{"type":"string","minLength":1},"instance_id":{"type":"string","minLength":1},"attestation":{"enum":["local_socket","process_credentials","signed_token","none"]}}},
    "capability": {"type":"object","additionalProperties":false,"required":["name","version"],"properties":{"name":{"type":"string","minLength":1},"version":{"type":"string","minLength":1}}}
  },
  "oneOf": [
    {
      "title": "Request",
      "required": ["protocol_version", "operation", "request_id", "actor", "timeout_ms", "payload"],
      "properties": {
        "protocol_version": {"const": "weave.ipc.v1"},
        "operation": {"type": "string", "minLength": 1},
        "request_id": {"type": "string", "minLength": 1},
        "repository": {"$ref": "#/$defs/repository_identity"},
        "actor": {"$ref":"#/$defs/actor"},
        "session_id": {"type": ["string", "null"]},
        "timeout_ms": {"type": "integer", "minimum": 1, "description":"Relative timeout measured by the receiving service after dispatch; never a wall-clock deadline."},
        "expected_graph_revision": {"type": ["integer", "null"], "minimum": 0},
        "idempotency_key": {"type": ["string", "null"]},
        "payload": {"type": "object"}
      },
      "additionalProperties": false
    },
    {
      "title": "Response",
      "required": ["protocol_version", "operation", "request_id", "server_version", "selected_protocol_version", "server_capabilities", "advisories"],
      "properties": {
        "protocol_version": {"const": "weave.ipc.v1"},
        "request_id": {"type": "string", "minLength": 1},
        "operation": {"type": "string", "minLength": 1},
        "server_version": {"type": "string", "minLength": 1},
        "selected_protocol_version":{"const":"weave.ipc.v1"},
        "server_capabilities":{"type":"array","items":{"$ref":"#/$defs/capability"},"uniqueItems":true},
        "graph_revision": {"type": ["integer","null"], "minimum": 0},
        "result": {"type": "object"},
        "error": {"$ref": "#/$defs/error"},
        "advisories": {"type": "array", "items": {"type": "object"}},
        "bounds": {"$ref": "#/$defs/bounds"},
        "durability": {"oneOf":[{"$ref": "#/$defs/durability"},{"type":"null"}]}
      },
      "additionalProperties": false,
      "oneOf": [
        {"required": ["result"], "properties": {"result": true, "error": false}},
        {"required": ["error"], "properties": {"result": false, "error": true}}
      ]
    }
  ]
}
